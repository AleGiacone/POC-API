{
  "openrpc": "1.2.6",
  "info": {
    "title": "Percona JSON-RPC API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "name": "Local",
      "url": "http://localhost:3000"
    }
  ],
  "methods": [
    {
      "name": "getUsers",
      "summary": "Obtiene todos los usuarios de la base de datos",
      "params": [],
      "result": {
        "name": "users",
        "schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}